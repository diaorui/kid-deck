camera:
  host: 192.168.1.100       # Thingino camera IP
  user: root                # Camera SSH user
  password: "your-password" # Camera SSH password

server:
  host: 0.0.0.0
  port: 8080

plugins:
  alarm:
    alarms:
      - id: get_up
        label: Get up!
        enabled: false
        time: "07:00"
        days: [0, 1, 2, 3, 4, 5, 6]
        audio: ""            # Path to alarm audio file (WAV)
    volume: 60

  audio_player:
    folder: ./stories        # Path to story series directories
    playback_rate: 16000
    volume: 60
    schedule:
      stop_time: "23:00"

  yt_cast:
    channels: []             # YouTube channel handles, e.g. "@channelname"
    channel_enabled: {}
    uncast_duration: 60      # Auto-stop after N minutes (0 = no auto-stop)
