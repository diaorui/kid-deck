camera:
  host: 192.168.1.100       # Thingino camera IP
  user: root                # Camera SSH user
  password: "your-password" # Camera SSH password

server:
  host: 0.0.0.0
  port: 8080

plugins:
  alarm:
    alarms:
      - id: get_up
        label: Get up!
        enabled: false
        time: "07:00"
        days: [0, 1, 2, 3, 4, 5, 6]  # 0=Mon ... 6=Sun
        audio: ""            # Path to alarm audio file (WAV)
    volume: 60

  audio_player:
    folder: ./stories        # Path to story series directories
    playback_rate: 16000
    volume: 60
    schedule:
      stop_time: "23:00"

  podcast_player:
    feeds: {}                # Podcast RSS feeds, e.g. "My feed": {url: "https://example.com/feed.xml", enabled: true}

  yt_cast:
    channel_enabled: {}      # YouTube channel handles + enabled state, e.g. "@channelname": true
    uncast_duration: 40      # Auto-stop after N minutes (0 = no auto-stop)

  stream:
    screen_minutes_per_hour: 12   # Target visual share of played content
    max_video_minutes: 30         # Drop videos longer than this
    max_audio_minutes: 30         # Drop podcasts longer than this
    playlist_horizon_hours: 3.5   # Coverage budget for pool build
    yt_fetch_per_channel: 8
    podcast_keep_per_feed: 10
    feed_interval: 60
    schedule:
      stop_time: "21:00"          # Clock time auto-stop (like audio_player)
    channel_enabled: {}           # Same shape as yt_cast — copy from there
    feeds: {}                     # Same shape as podcast_player — copy from there
